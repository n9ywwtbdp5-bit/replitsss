@import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=Boogaloo&display=swap');

:root {
  /* Brand Colors */
  --brand-orange: #FF6B35;
  --brand-yellow: #FFD23F;
  --brand-green: #06D6A0;
  --brand-blue: #118AB2;
  --brand-purple: #9B5DE5;
  --brand-pink: #F72585;
  --brand-red: #EF233C;

  /* Surfaces */
  --bg-primary: #FFFBF5;
  --bg-card: #FFFFFF;
  --bg-card-hover: #FFF5EC;
  --border: #FFE4CC;
  --border-strong: #FFCFA3;

  /* Text */
  --text-primary: #1A1A2E;
  --text-secondary: #6B6B8A;
  --text-muted: #A9A9C0;

  /* Shadows */
  --shadow-sm: 0 2px 8px rgba(255,107,53,0.08);
  --shadow-md: 0 4px 20px rgba(255,107,53,0.12);
  --shadow-lg: 0 8px 40px rgba(255,107,53,0.16);
  --shadow-card: 0 4px 0 #FFD5B8;

  /* Radii */
  --radius-sm: 12px;
  --radius-md: 18px;
  --radius-lg: 24px;
  --radius-xl: 32px;
  --radius-full: 9999px;

  /* Fonts */
  --font-display: 'Boogaloo', cursive;
  --font-body: 'Nunito', sans-serif;

  /* Transitions */
  --ease-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
  --ease-smooth: cubic-bezier(0.4, 0, 0.2, 1);
}

*, *::before, *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

html {
  scroll-behavior: smooth;
}

body {
  font-family: var(--font-body);
  background-color: var(--bg-primary);
  color: var(--text-primary);
  -webkit-font-smoothing: antialiased;
  min-height: 100vh;
  overflow-x: hidden;
}

/* Scrollbar */
::-webkit-scrollbar { width: 6px; }
::-webkit-scrollbar-track { background: transparent; }
::-webkit-scrollbar-thumb { background: var(--brand-orange); border-radius: 3px; opacity: 0.4; }

/* Animations */
@keyframes float {
  0%, 100% { transform: translateY(0px); }
  50% { transform: translateY(-8px); }
}
@keyframes pulse-glow {
  0%, 100% { box-shadow: 0 0 0 0 rgba(255,107,53,0.4); }
  50% { box-shadow: 0 0 0 12px rgba(255,107,53,0); }
}
@keyframes slide-up {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
@keyframes pop-in {
  0% { opacity: 0; transform: scale(0.8); }
  70% { transform: scale(1.05); }
  100% { opacity: 1; transform: scale(1); }
}
@keyframes shimmer {
  0% { background-position: -200% center; }
  100% { background-position: 200% center; }
}
@keyframes wiggle {
  0%, 100% { transform: rotate(-3deg); }
  50% { transform: rotate(3deg); }
}
@keyframes streak-fire {
  0%, 100% { transform: scaleY(1) rotate(-2deg); }
  50% { transform: scaleY(1.1) rotate(2deg); }
}
@keyframes confetti-fall {
  0% { transform: translateY(-100vh) rotate(0deg); opacity: 1; }
  100% { transform: translateY(100vh) rotate(720deg); opacity: 0; }
}
@keyframes xp-bar {
  from { width: 0; }
  to { width: var(--xp-width); }
}

.animate-slide-up { animation: slide-up 0.5s var(--ease-smooth) both; }
.animate-pop-in { animation: pop-in 0.4s var(--ease-bounce) both; }
.animate-float { animation: float 3s ease-in-out infinite; }
.animate-wiggle { animation: wiggle 0.5s ease-in-out infinite; }

/* Card base */
.card {
  background: var(--bg-card);
  border-radius: var(--radius-lg);
  border: 2px solid var(--border);
  box-shadow: var(--shadow-card);
  transition: transform 0.2s var(--ease-bounce), box-shadow 0.2s ease;
}
.card:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 0 #FFD5B8, var(--shadow-md);
}

/* Button styles */
.btn {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 28px;
  border-radius: var(--radius-full);
  font-family: var(--font-body);
  font-weight: 800;
  font-size: 1rem;
  border: none;
  cursor: pointer;
  transition: transform 0.15s var(--ease-bounce), box-shadow 0.15s ease;
  text-decoration: none;
  white-space: nowrap;
}
.btn:active { transform: scale(0.96) translateY(2px); }

.btn-primary {
  background: var(--brand-orange);
  color: white;
  box-shadow: 0 4px 0 #C94E1F;
}
.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 0 #C94E1F;
}

.btn-secondary {
  background: white;
  color: var(--brand-orange);
  border: 2.5px solid var(--brand-orange);
  box-shadow: 0 4px 0 var(--border-strong);
}
.btn-secondary:hover {
  background: var(--bg-card-hover);
  transform: translateY(-2px);
  box-shadow: 0 6px 0 var(--border-strong);
}

.btn-green {
  background: var(--brand-green);
  color: white;
  box-shadow: 0 4px 0 #049E78;
}
.btn-green:hover { transform: translateY(-2px); box-shadow: 0 6px 0 #049E78; }

/* XP Bar */
.xp-bar-container {
  background: var(--border);
  border-radius: var(--radius-full);
  height: 12px;
  overflow: hidden;
}
.xp-bar-fill {
  height: 100%;
  border-radius: var(--radius-full);
  background: linear-gradient(90deg, var(--brand-orange), var(--brand-yellow));
  background-size: 200% auto;
  animation: shimmer 2s linear infinite;
  transition: width 1s var(--ease-bounce);
}

/* Streak badge */
.streak-badge {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  background: linear-gradient(135deg, #FF6B35, #FFD23F);
  color: white;
  border-radius: var(--radius-full);
  padding: 6px 16px;
  font-weight: 900;
  font-size: 1.1rem;
  box-shadow: 0 3px 0 #C94E1F;
  animation: pulse-glow 2s ease-in-out infinite;
}

/* Modal overlay */
.modal-overlay {
  position: fixed;
  inset: 0;
  background: rgba(26,26,46,0.7);
  backdrop-filter: blur(8px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  padding: 16px;
  animation: slide-up 0.3s ease both;
}
.modal-box {
  background: white;
  border-radius: var(--radius-xl);
  padding: 40px;
  max-width: 520px;
  width: 100%;
  position: relative;
  box-shadow: 0 24px 80px rgba(0,0,0,0.2);
  animation: pop-in 0.35s var(--ease-bounce) both;
}

/* Nav */
.nav-link {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding: 10px 20px;
  border-radius: var(--radius-md);
  color: var(--text-secondary);
  font-weight: 700;
  font-size: 0.8rem;
  text-decoration: none;
  transition: all 0.2s var(--ease-bounce);
  border: 2px solid transparent;
}
.nav-link:hover, .nav-link.active {
  color: var(--brand-orange);
  background: var(--bg-card-hover);
  border-color: var(--border);
}
.nav-link.active { box-shadow: var(--shadow-sm); }

/* Responsive */
@media (max-width: 768px) {
  .modal-box { padding: 28px 20px; }
}
